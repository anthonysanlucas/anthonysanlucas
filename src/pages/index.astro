---
import Base from '@/layouts/Base.astro'
import Me from '@/components/home/Me.astro'
import ContactInfo from '@/components/home/ContactInfo'
import Section from '@/components/Section.astro'
import ProjectCard from '@/components/ProjectCard.astro'

const organizations = [
  { name: 'Tecnova', src: '/images/organizations/tecnova.svg' },
  { name: 'Masapp', src: '/images/organizations/masapp.svg' },
  { name: 'Ferrara', src: '/images/organizations/ferrara.svg' },
  { name: 'Fortclub', src: '/images/organizations/fortclub.svg' },
  { name: 'Jobsa', src: '/images/organizations/jobsa.svg' },
  { name: 'Naturisa', src: '/images/organizations/naturisa.svg' },
  { name: 'VG Courier', src: '/images/organizations/vgcourier.svg' }
]

const projects = [
  {
    title: 'Memmorable',
    subtitle: 'Invitaciones digitales hermosas y fáciles de usar',
    domain: 'memmorable.com',
    href: 'https://memmorable.com',
    logoUrl: '/images/projects/memmorable_favicon.svg',
    imageUrl: '/images/projects/memmorable.png'
  },
  {
    title: 'Calculadora UG',
    subtitle: 'Simulador de Calificaciones Universidad Guayaquil',
    domain: 'calculadoraug.com',
    href: 'https://calculadoraug.asanlucas.com',
    logoUrl: '/images/projects/calculadoraug_favicon.svg',
    imageUrl: '/images/projects/calculadoraug.png'
  },
  {
    title: 'Lumo',
    subtitle:
      'Aplicación de notas, diseñada para ayudarte a concentrarte en lo que realmente importa.',
    domain: 'lumoclarity.com',
    href: 'https://lumoclarity.com',
    logoUrl: '/images/projects/lumo_favicon.svg',
    imageUrl: '/images/projects/lumo.webp'
  }
]
---

<Base
  titlePage="Anthony San Lucas | Desarrollador de Software | Frontend | Web | Móvil | Tecnologías de la Información"
  descriptionPage="🚀 Desarrollador de Software - Web / Móvil | Tecnologías de la Información | Ecuador / Guayaquil"
  currentUrl="">
  <div
    class="absolute inset-0 -z-10 h-full w-full bg-white bg-[linear-gradient(to_right,#8080800a_1px,transparent_1px),linear-gradient(to_bottom,#8080800a_1px,transparent_1px)] bg-[size:14px_24px]">
  </div>

  <section class="flex flex-col lg:flex-row lg:items-start pb-16">
    <Me />

    <section class="w-full lg:ml-12">
      <Section title="Empresas y organizaciones con las que he colaborado" icon="🏢">
        <article class="flex flex-wrap items-center justify-start gap-4 sm:gap-6">
          {
            organizations.map(org => (
              <div
                class="flex h-20 w-full sm:w-40 items-center justify-center rounded-xl border border-gray-200 bg-white px-4 shadow-sm transition hover:bg-slate-50"
                title={org.name}>
                <img
                  src={org.src}
                  alt={`Logo de ${org.name}`}
                  class="h-10 w-full object-contain"
                  loading="lazy"
                />
              </div>
            ))
          }
        </article>
      </Section>

      <Section title="Mis Aplicaciones" icon="🚀">
        <div class="grid grid-cols-1 gap-4">
          {projects.map(p => <ProjectCard {...p} />)}
        </div>
      </Section>

      <Section title={'Información de contacto'} icon="📬">
        <ContactInfo client:idle />
      </Section>
    </section>
  </section>
</Base>
