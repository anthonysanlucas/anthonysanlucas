---
type Props = {
  title: string
  subtitle: string
  domain: string
  href: string
  logoUrl: string
  imageUrl: string
  isSkeleton?: boolean
}

const { title, subtitle, domain, href, logoUrl, imageUrl } = Astro.props
---

<article class="rounded-2xl border border-dashed border-gray-200 bg-white shadow-sm">
  <a
    href={href}
    target="_blank"
    rel="noreferrer"
    class="flex items-stretch justify-between gap-3 p-4 sm:gap-4 sm:p-5"
    title={title}>
    <section class="min-w-0 flex-1">
      <div class="flex items-start gap-3">
        <div
          class="mt-0.5 h-10 w-10 shrink-0 overflow-hidden rounded-full border border-gray-200 bg-gray-50">
          <img
            src={logoUrl}
            alt={`${title} logo`}
            class="h-full w-full object-cover text-black/60"
            loading="lazy"
          />
        </div>

        <div class="min-w-0 space-y-1.5">
          <div class="min-w-0">
            <p class="text-sm font-semibold leading-5 text-gray-900">{title}</p>
            <p class="text-xs leading-4 text-gray-500">{subtitle}</p>
          </div>
          <span
            class="inline-flex max-w-full items-center rounded-full border border-gray-200 bg-gray-50 px-2 py-0.5 text-[11px] font-medium text-gray-500">
            <span class="truncate">{domain}</span>
          </span>
        </div>
      </div>
    </section>

    <section class="group/preview relative h-16 w-28 shrink-0 overflow-hidden sm:h-20 sm:w-36">
      <img
        src={imageUrl}
        alt={`${title} preview`}
        class="h-full w-full object-cover rounded-xl object-top opacity-90 transition duration-300 group-hover/preview:scale-[1.02]"
        loading="lazy"
      />
      <div
        class="pointer-events-none absolute inset-y-0 left-0 w-5 bg-gradient-to-r from-white/65 to-transparent">
      </div>
      <div
        class="pointer-events-none absolute inset-x-0 top-0 h-5 bg-gradient-to-b from-white/55 via-white/10 to-transparent">
      </div>
      <div class="pointer-events-none absolute inset-0"></div>
    </section>
  </a>
</article>
