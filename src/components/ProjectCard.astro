---
type Props = {
  title: string
  subtitle: string
  domain: string
  href: string
  logoUrl: string
  imageUrl: string
}

const { title, subtitle, domain, href, logoUrl, imageUrl } = Astro.props
---

<a
  href={href}
  target="_blank"
  rel="noreferrer"
  class="group block rounded-2xl border border-gray-200 bg-white shadow-sm transition hover:bg-slate-50">
  <div class="flex items-stretch justify-between gap-4 p-4 sm:p-5">
    <!-- Left -->
    <div class="min-w-0 flex-1">
      <div class="flex items-center gap-3">
        <div
          class="h-10 w-10 shrink-0 overflow-hidden rounded-xl border border-gray-200 bg-gray-50">
          <img
            src={logoUrl}
            alt={`${title} logo`}
            class="h-full w-full object-cover"
            loading="lazy"
          />
        </div>

        <div class="min-w-0">
          <p class="truncate text-sm font-semibold text-gray-900">
            {title}
            <span class="font-normal text-gray-500">- {subtitle}</span>
          </p>
          <p class="truncate text-xs text-gray-400">{domain}</p>
        </div>
      </div>
    </div>

    <!-- Right image -->
    <div class="relative h-16 w-28 shrink-0 overflow-hidden rounded-xl bg-gray-100 sm:h-20 sm:w-36">
      <img
        src={imageUrl}
        alt={`${title} preview`}
        class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.03]"
        loading="lazy"
      />
      <div class="pointer-events-none absolute inset-0 ring-1 ring-inset ring-black/5"></div>
    </div>
  </div>
</a>
