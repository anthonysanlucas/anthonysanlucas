---
import ProjectCard from './ProjectCard.astro'

const projects = [
  {
    title: 'Memmorable',
    subtitle: 'Invitaciones digitales hermosas y fáciles de usar',
    domain: 'memmorable.com',
    href: 'https://memmorable.com',
    logoUrl: '/images/logos/ellie.png',
    imageUrl: '/images/previews/ellie.png'
  },
  {
    title: 'De Platos',
    subtitle: 'Menús increíbles para restaurantes',
    domain: 'deplatos.com',
    href: 'https://deplatos.com',
    logoUrl: '/images/logos/lily.png',
    imageUrl: '/images/previews/lily.png'
  },
  {
    title: 'Calculadora UG',
    subtitle: 'Simulador de Calificaciones Universidad Guayaquil',
    domain: 'mogulnetworking.com',
    href: 'https://mogulnetworking.com',
    logoUrl: '/images/logos/mogul.png',
    imageUrl: '/images/previews/mogul.png'
  }
]
---

<section class="mx-auto max-w-5xl px-4 py-10 sm:px-6">
