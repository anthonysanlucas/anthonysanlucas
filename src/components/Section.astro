---
type Props = {
  title: string
  icon?: string
}

const { title, icon = '✨' } = Astro.props
---

<section class="mx-auto max-w-5xl px-4 py-10 sm:px-6">
  <div class="mb-5 flex items-center gap-2">
    <span class="text-lg">{icon}</span>
    <h2 class="text-lg font-semibold text-gray-900">
      {title}
    </h2>
  </div>

  <slot />
</section>
